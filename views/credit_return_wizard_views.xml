<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reza_fsm_credit_return_wizard_form" model="ir.ui.view">
        <field name="name">reza.fsm.credit.return.wizard.form</field>
        <field name="model">reza.fsm.credit.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Credit / Return" class="o_reza_credit_return_wizard">
                <sheet>
                    <group>
                        <field name="task_id"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                        <field name="allowed_return_location_ids" invisible="1"/>
                    </group>
                    <button
                        name="action_add_from_catalog"
                        string="Add Products"
                        type="object"
                        class="btn-secondary mb-2"
                    />
                    <field name="line_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="allowed_return_location_ids" column_invisible="True"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="product_uom_id" optional="hide"/>
                            <field name="price_unit" optional="hide"/>
                            <field name="outcome"/>
                            <field
                                name="return_location_id"
                                required="outcome == 'credit_return'"
                                invisible="outcome != 'credit_return'"
                            />
                            <field
                                name="credit_reason_ids"
                                widget="many2many_tags"
                                required="outcome == 'credit_return'"
                            />
                            <field
                                name="scrap_reason_id"
                                required="outcome == 'credit_scrap'"
                                invisible="outcome != 'credit_scrap'"
                            />
                            <field name="note" optional="hide"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button
                        name="action_create_credit_note"
                        string="Create &amp; Confirm Credit Note"
                        type="object"
                        class="btn-primary"
                    />
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_reza_fsm_credit_return_wizard" model="ir.actions.act_window">
        <field name="name">Credit / Return</field>
        <field name="res_model">reza.fsm.credit.return.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

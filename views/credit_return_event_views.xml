<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reza_fsm_credit_return_event_list" model="ir.ui.view">
        <field name="name">reza.fsm.credit.return.event.list</field>
        <field name="model">reza.fsm.credit.return.event</field>
        <field name="arch" type="xml">
            <list string="Credit Returns" create="0">
                <field name="date"/>
                <field name="outcome"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="quantity"/>
                <field name="product_uom_id"/>
                <field name="return_location_id"/>
                <field name="credit_reason_ids" widget="many2many_tags"/>
                <field name="scrap_reason_id"/>
                <field name="user_id"/>
                <field name="move_id"/>
                <field name="task_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_reza_fsm_credit_return_event_form" model="ir.ui.view">
        <field name="name">reza.fsm.credit.return.event.form</field>
        <field name="model">reza.fsm.credit.return.event</field>
        <field name="arch" type="xml">
            <form string="Credit Return">
                <sheet>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="state"/>
                            <field name="outcome"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="move_id"/>
                            <field name="move_line_id"/>
                            <field name="task_id"/>
                            <field name="stock_move_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="return_location_id" invisible="outcome != 'credit_return'"/>
                        <field name="credit_reason_ids" widget="many2many_tags"/>
                        <field name="scrap_reason_id" invisible="outcome != 'credit_scrap'"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_reza_fsm_credit_return_event_search" model="ir.ui.view">
        <field name="name">reza.fsm.credit.return.event.search</field>
        <field name="model">reza.fsm.credit.return.event</field>
        <field name="arch" type="xml">
            <search string="Credit Returns">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <field name="return_location_id"/>
                <filter name="credit_return" string="Credit Return" domain="[('outcome', '=', 'credit_return')]"/>
                <filter name="credit_scrap" string="Credit Scrap" domain="[('outcome', '=', 'credit_scrap')]"/>
                <group>
                    <filter name="group_outcome" string="Outcome" domain="[]" context="{'group_by':'outcome'}"/>
                    <filter name="group_customer" string="Customer/Store" domain="[]" context="{'group_by':'partner_id'}"/>
                    <filter name="group_product" string="Product" domain="[]" context="{'group_by':'product_id'}"/>
                    <filter name="group_rep" string="Rep" domain="[]" context="{'group_by':'user_id'}"/>
                    <filter name="group_location" string="Location" domain="[]" context="{'group_by':'return_location_id'}"/>
                    <filter name="group_date" string="Date" domain="[]" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_reza_fsm_credit_return_event_pivot" model="ir.ui.view">
        <field name="name">reza.fsm.credit.return.event.pivot</field>
        <field name="model">reza.fsm.credit.return.event</field>
        <field name="arch" type="xml">
            <pivot string="Credit Returns">
                <field name="quantity" type="measure"/>
                <field name="outcome" type="row"/>
                <field name="product_id" type="row"/>
                <field name="partner_id" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="action_reza_fsm_credit_return_event" model="ir.actions.act_window">
        <field name="name">Credit Returns</field>
        <field name="res_model">reza.fsm.credit.return.event</field>
        <field name="view_mode">list,pivot,form</field>
        <field name="search_view_id" ref="view_reza_fsm_credit_return_event_search"/>
    </record>

    <menuitem
        id="menu_reza_fsm_credit_return_event"
        name="Credit Returns"
        parent="industry_fsm.fsm_menu_reporting"
        action="action_reza_fsm_credit_return_event"
        groups="reza_field_service_buttons.group_liaise_field_rep,reza_field_service_buttons.group_fsm_controllers"
        sequence="25"/>
</odoo>

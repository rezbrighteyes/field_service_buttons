<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Manager form view with larger images -->
    <record id="view_liaise_worksheet_report_form" model="ir.ui.view">
        <field name="name">liaise.worksheet.report.form</field>
        <field name="model">x_project_task_worksheet_template_3</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <form string="Liaise Worksheet Visit">
                <sheet>
                    <group>
                        <group string="Visit Info">
                            <field name="x_project_task_id" string="Store"/>
                            <field name="create_uid" string="Rep"/>
                            <field name="create_date" string="Date"/>
                        </group>
                        <group string="Visit Summary">
                            <field name="x_order_placed" string="Order Placed"/>
                        </group>
                    </group>
                    <separator string="Display Photos"/>
                    <group>
                        <group>
                            <field name="x_display_photo" string="Photo 1" widget="image" options="{'size': [600, 400]}"/>
                            <field name="x_photo_1_caption" string="Caption"/>
                        </group>
                        <group>
                            <field name="x_display_photo_2" string="Photo 2" widget="image" options="{'size': [600, 400]}"/>
                            <field name="x_photo_2_caption" string="Caption"/>
                        </group>
                        <group>
                            <field name="x_display_photo_3" string="Photo 3" widget="image" options="{'size': [600, 400]}"/>
                            <field name="x_photo_3_caption" string="Caption"/>
                        </group>
                        <group>
                            <field name="x_display_photo_4" string="Photo 4" widget="image" options="{'size': [600, 400]}"/>
                            <field name="x_photo_4_caption" string="Caption"/>
                        </group>
                    </group>
                    <separator string="Stock Levels"/>
                    <group>
                        <group>
                            <field name="x_thongs" string="Thongs"/>
                            <field name="x_sunnies" string="Sunnies"/>
                            <field name="x_hats" string="Hats"/>
                        </group>
                        <group>
                            <field name="x_tech" string="Tech"/>
                            <field name="x_outdoor" string="Outdoor / Other"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="x_notes" string="Notes"/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="view_liaise_worksheet_report_list" model="ir.ui.view">
        <field name="name">liaise.worksheet.report.list</field>
        <field name="model">x_project_task_worksheet_template_3</field>
        <field name="arch" type="xml">
            <list string="Liaise Worksheet Visits" create="false">
                <field name="create_date" string="Date"/>
                <field name="x_project_task_id" string="Store"/>
                <field name="create_uid" string="Rep"/>
                <field name="x_thongs" string="Thongs"/>
                <field name="x_sunnies" string="Sunnies"/>
                <field name="x_hats" string="Hats"/>
                <field name="x_tech" string="Tech"/>
                <field name="x_outdoor" string="Outdoor / Other"/>
                <field name="x_order_placed" string="Order Placed"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_liaise_worksheet_report" model="ir.actions.act_window">
        <field name="name">Liaise Worksheet Visits</field>
        <field name="res_model">x_project_task_worksheet_template_3</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Explicitly bind list view to action -->
    <record id="action_view_liaise_list" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_liaise_worksheet_report"/>
        <field name="view_id" ref="view_liaise_worksheet_report_list"/>
        <field name="view_mode">list</field>
        <field name="sequence">1</field>
    </record>

    <!-- Explicitly bind form view to action -->
    <record id="action_view_liaise_form" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_liaise_worksheet_report"/>
        <field name="view_id" ref="view_liaise_worksheet_report_form"/>
        <field name="view_mode">form</field>
        <field name="sequence">2</field>
    </record>

    <!-- Menu under Field Service > Reporting -->
    <menuitem
        id="menu_liaise_worksheet_report"
        name="Liaise Worksheet Visits"
        parent="industry_fsm.fsm_menu_reporting"
        action="action_liaise_worksheet_report"
        sequence="20"/>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_fsm_credit_return" model="ir.ui.view">
        <field name="name">account.move.form.fsm.credit.return</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <widget
                    name="signature"
                    string="Sign"
                    highlight="1"
                    invisible="is_signed or move_type != 'out_refund'"
                    full_name="partner_id"
                />
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field
                    name="reza_fsm_task_id"
                    readonly="1"
                    invisible="not reza_fsm_task_id"
                />
                <field
                    name="is_signed"
                    invisible="1"
                />
                <field
                    name="signed_by"
                    readonly="1"
                    invisible="not signature"
                />
                <field
                    name="signed_on"
                    readonly="1"
                    invisible="not signature"
                />
                <field
                    name="signature"
                    widget="image"
                    readonly="1"
                    invisible="not signature"
                />
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='quantity']" position="after">
                <field name="reza_fsm_credit_return_outcome" optional="show"/>
                <field name="reza_fsm_credit_return_location_id" optional="show"/>
                <field name="reza_fsm_credit_reason_ids" widget="many2many_tags" optional="hide"/>
                <field name="reza_fsm_scrap_reason_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>

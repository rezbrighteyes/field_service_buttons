<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Remove orphaned state-filter view left in the database by a previous upgrade -->
    <delete model="ir.ui.view" search="[('name', '=', 'project.task.form2.fsm.state.filter')]"/>

    <record id="view_task_form_fsm_reza_buttons" model="ir.ui.view">
        <field name="name">project.task.form.fsm.reza.buttons</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="industry_fsm.view_task_form2_inherit"/>
        <field name="arch" type="xml">
            <button name="action_fsm_validate" position="before">
                <button
                    name="action_create_sale_order"
                    string="Order"
                    type="object"
                    class="btn-primary"
                    icon="fa-shopping-cart"
                />
                <button
                    name="action_create_credit_note"
                    string="Credit Note"
                    type="object"
                    class="btn-secondary"
                    icon="fa-file-text-o"
                />
            </button>
            <field name="partner_id" position="after">
                <field name="fsm_next_visit_date"/>
                <field name="fsm_next_visit_date_manual" invisible="1"/>
                <field
                    name="fsm_cancellation_reason"
                    invisible="not parent_id"
                    placeholder="Required before cancelling a sub-task"
                />
            </field>
        </field>
    </record>
</odoo>

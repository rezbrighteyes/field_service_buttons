<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_fsm_credit_signature" inherit_id="account.report_invoice_document">
        <xpath expr="//table[@name='invoice_line_table']" position="after">
            <div
                t-if="o.move_type == 'out_refund' and (o.reza_fsm_customer_signature or o.signature)"
                name="reza_fsm_customer_signature"
                class="mt-3"
                style="page-break-inside: avoid;"
            >
                <p class="mb-1">
                    <strong>Customer Signature</strong>
                </p>
                <img
                    t-att-src="image_data_uri(o.reza_fsm_customer_signature or o.signature)"
                    style="max-height: 90px; max-width: 260px;"
                    alt="Customer signature"
                />
                <p class="mb-0" style="font-size: 11px;">
                    Signed by
                    <span t-out="o.reza_fsm_customer_signed_by or o.signed_by or o.partner_id.name"/>
                    <t t-if="o.reza_fsm_customer_signed_on or o.signed_on">
                        on
                        <span
                            t-if="o.reza_fsm_customer_signed_on"
                            t-field="o.reza_fsm_customer_signed_on"
                        />
                        <span t-else="" t-field="o.signed_on"/>
                    </t>
                </p>
            </div>
        </xpath>
    </template>
</odoo>

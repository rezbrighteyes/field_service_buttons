<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_fsm_controllers" model="res.groups">
        <field name="name">FSM Controllers</field>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>

    <record id="group_liaise_field_rep" model="res.groups">
        <field name="name">Liaise Field Rep</field>
        <field name="implied_ids" eval="[
            (4, ref('industry_fsm.group_fsm_user')),
            (4, ref('sales_team.group_sale_salesman')),
            (4, ref('stock.group_stock_user')),
            (4, ref('purchase.group_purchase_user')),
            (4, ref('account.group_account_readonly'))
        ]"/>
    </record>

    <!-- Internal users who are NOT in FSM Controllers can only access non-FSM tasks -->
    <record id="rule_project_task_internal_non_fsm_only" model="ir.rule">
        <field name="name">Project Task: Internal Non-FSM Only</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('is_fsm', '=', False)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- FSM Controllers can access FSM tasks -->
    <record id="rule_project_task_fsm_controllers_fsm_only" model="ir.rule">
        <field name="name">Project Task: FSM Controllers FSM Access</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('reza_field_service_buttons.group_fsm_controllers'))]"/>
        <field name="domain_force">[('is_fsm', '=', True)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_credit_return_event_rep_own" model="ir.rule">
        <field name="name">Credit Return Events: Field Service Own</field>
        <field name="model_id" ref="model_reza_fsm_credit_return_event"/>
        <field name="groups" eval="[(4, ref('industry_fsm.group_fsm_user'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_credit_return_event_controller_all" model="ir.rule">
        <field name="name">Credit Return Events: Controllers All</field>
        <field name="model_id" ref="model_reza_fsm_credit_return_event"/>
        <field name="groups" eval="[(4, ref('reza_field_service_buttons.group_fsm_controllers'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
